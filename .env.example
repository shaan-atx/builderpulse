# Anthropic API key with usage:read scope
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key
OPENAI_API_KEY=sk-...

# Secret token for POST /api/manual (curl-based logging)
# Authorization: Bearer <this value>
MANUAL_LOG_SECRET=change-me

# Optional defaults for the widget
DEFAULT_COLOR_SCHEME=purple
DEFAULT_THEME=dark
