# Anthropic ADMIN API key — must be an Admin key (sk-ant-admin-...), not a regular API key.
# Create one at: console.anthropic.com → Settings → API keys → Create Admin key
ANTHROPIC_API_KEY=sk-ant-admin-...

# OpenAI API key with the api.usage.read scope enabled.
# Create one at: platform.openai.com → API keys → Create new secret key → add Usage scope
OPENAI_API_KEY=sk-...

# Secret token for POST /api/manual (curl-based logging)
# Authorization: Bearer <this value>
MANUAL_LOG_SECRET=change-me

# Optional defaults for the widget
DEFAULT_COLOR_SCHEME=purple
DEFAULT_THEME=dark
